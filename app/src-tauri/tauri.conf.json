{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Iris",
  "version": "0.1.0",
  "identifier": "lt.rot.iris",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1423",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "cargo build --release -p iris-service && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Iris",
        "width": 980,
        "height": 720,
        "minWidth": 820,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "withGlobalTauri": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lintowe/iris/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxQUYxRjhBNzgxMUQ5QkUKUldTKzJSRjRpaCt2Z2RVVmZJcEZLbVExYXJyTFZJQTB6S0VUNkFXdXUvZ1Y0THZUV3VYeVZTN3UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/geo/dbip-country.mmdb": "resources/geo/dbip-country.mmdb",
      "../../target/release/iris-engine.exe": "engine/iris-engine.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "© rot",
    "shortDescription": "Firewall and network monitor",
    "longDescription": "Iris watches every app's network traffic and puts you in control of what is allowed to connect. A native firewall and live monitor for Windows."
  }
}
